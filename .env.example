# Copy to .env and fill in as needed. Every value is optional — the scanner
# runs without any of this configured; Postgres-backed reporting is disabled
# and defaults below are used for HTTP tuning.

# --- Optional Postgres reporting ---
DB_HOST=localhost
DB_DATABASE=vulnerability_scanner
DB_USER=postgres
DB_PASSWORD=
DB_PORT=5432

# --- HTTP / crawl tuning (seconds unless noted) ---
SCAN_HTTP_TIMEOUT=30
SCAN_HTTP_TIMEOUT_RETRY=60
SCAN_JITTER=0
SCAN_CRAWL_TIMEOUT=10
SCAN_CRAWL_THREADS=8
SCAN_CRAWL_LIMIT=40
SCAN_PARAM_LINK_LIMIT=200
SCAN_TRAINING_CRAWL_LIMIT=40
SCAN_RECON_TIMEOUT=30
SCAN_CONNECT_TIMEOUT=15
SCAN_PROBE_CONNECT_TIMEOUT=15
SCAN_REQUEST_DELAY=0
SCAN_BACKOFF_SECONDS=0

# --- Proxy (e.g. route traffic through Burp/ZAP) ---
SCAN_PROXY=
SCAN_AUTO_PROXY=false

# --- SQLi tuning ---
SCAN_SQLI_WORKERS=10
SCAN_SQLI_PROBE_ALL_COOKIES=false

# --- Reporting ---
SCAN_SHOW_CANDIDATES=false

# --- CSRF authenticated-scan credentials (only for targets you are authorized to test) ---
CSRF_USER=
CSRF_PASS=
CSRF_USER2=
CSRF_PASS2=
