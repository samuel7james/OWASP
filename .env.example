# Copy to .env and fill in as needed. Every value is optional — the scanner
# runs fine with none of it set. Per-run scan behavior (concurrency, timeout,
# request pacing) is controlled by `--profile` (fast/thorough/stealth), not
# environment variables — see docs/USER_GUIDE.md.

# --- SQLi/XSS/CSRF module concurrency ---
SCAN_SQLI_WORKERS=10

# --- Also probe session/tracking cookies normally excluded by denylist ---
SCAN_SQLI_PROBE_ALL_COOKIES=false
